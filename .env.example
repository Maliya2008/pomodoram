# ==============================================================================
# POMODORAM — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# Add ALL of these to: Vercel → Project Settings → Environment Variables
# ==============================================================================

# ------------------------------------------------------------------------------
# DATABASE (Turso — Cloud libSQL)
# Sign up at https://turso.tech/ → create a database → copy the URL + token
# For local development, use: file:dev.db
# For production (Vercel), use: libsql://your-db-name-username.turso.io
# ------------------------------------------------------------------------------
DATABASE_URL="libsql://your-db-name.turso.io"
DATABASE_AUTH_TOKEN="your-turso-auth-token-here"

# ------------------------------------------------------------------------------
# JWT SECRET — used to sign authentication tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be at least 32 characters — keep it secret!
# ------------------------------------------------------------------------------
JWT_SECRET="replace-with-a-very-long-random-secret-minimum-32-chars"

# ------------------------------------------------------------------------------
# NEXT.JS PUBLIC URL (used for OG image base URL, canonical links)
# In development: http://localhost:3000
# In production (Vercel): https://your-project.vercel.app
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"
